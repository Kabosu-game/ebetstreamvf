# URL de l'API Laravel backend
LARAVEL_API_URL=https://api.ebetstream.live/api

# Token interne partagé avec Laravel (LARAVEL_INTERNAL_TOKEN dans .env Laravel)
LARAVEL_INTERNAL_TOKEN=

# Port — NE PAS définir sur o2switch, Phusion Passenger l'injecte automatiquement via PORT
# Sur VPS classique uniquement : décommenter et définir le port souhaité
# STREAM_WS_PORT=8082
